# Runtime
SCIDATA_ENVIRONMENT=local
SCIDATA_LOG_LEVEL=INFO
SCIDATA_DATA_DIR=var
SCIDATA_OFFLINE_MODE=true

# Alibaba Cloud Model Studio (Bailian/Qwen)
# Never commit a real key. Model calls remain disabled while offline mode is true.
DASHSCOPE_API_KEY=
SCIDATA_BAILIAN_REGION=cn-beijing
SCIDATA_BAILIAN_WORKSPACE_ID=
# Optional endpoint override for tests or an official legacy endpoint:
# SCIDATA_QWEN_BASE_URL=
SCIDATA_PLANNER_MODEL_ID=qwen-plus
SCIDATA_FAST_MODEL_ID=qwen-turbo
SCIDATA_CRITIC_MODEL_ID=qwen-plus
SCIDATA_MODEL_TIMEOUT_SECONDS=30
SCIDATA_MODEL_MAX_RETRIES=2
SCIDATA_MODEL_MAX_CONCURRENCY=4

# Default task guardrails
SCIDATA_DEFAULT_MAX_SOURCES=50
SCIDATA_DEFAULT_MAX_DOWNLOAD_BYTES=524288000
SCIDATA_DEFAULT_MODEL_TOKEN_BUDGET=100000
