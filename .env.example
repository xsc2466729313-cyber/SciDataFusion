# Runtime
SCIDATA_ENVIRONMENT=local
SCIDATA_LOG_LEVEL=INFO
SCIDATA_DATA_DIR=var
SCIDATA_OFFLINE_MODE=true

# Alibaba Cloud Model Studio (Bailian/Qwen)
# Never commit a real key. Model calls remain disabled while offline mode is true.
DASHSCOPE_API_KEY=
SCIDATA_BAILIAN_REGION=cn-beijing
SCIDATA_BAILIAN_WORKSPACE_ID=
# Official Beijing OpenAI-compatible endpoint. The local web form can update it.
SCIDATA_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
SCIDATA_PLANNER_MODEL_ID=qwen-plus
SCIDATA_FAST_MODEL_ID=qwen-turbo
SCIDATA_CRITIC_MODEL_ID=qwen-plus
SCIDATA_MODEL_TIMEOUT_SECONDS=30
SCIDATA_MODEL_MAX_RETRIES=2
SCIDATA_MODEL_MAX_CONCURRENCY=4

# Live web discovery (SerpApi). Keep the real key only in the ignored .env file.
SERPAPI_API_KEY=
SCIDATA_SEARCH_TIMEOUT_SECONDS=20
SCIDATA_SEARCH_MAX_RETRIES=2
SCIDATA_SEARCH_MAX_CONCURRENCY=2
SCIDATA_SEARCH_MIN_INTERVAL_SECONDS=0.25
SCIDATA_SEARCH_CACHE_TTL_SECONDS=900
SCIDATA_SEARCH_MAX_RESULTS=20
SCIDATA_SEARCH_ENGINE=google
SCIDATA_SEARCH_LANGUAGE=zh-cn
# Optional two-letter country code, for example cn, us, or gb.
SCIDATA_SEARCH_COUNTRY=
# Qwen may create several bounded search queries from the research goal and seed query.
SCIDATA_SEARCH_QUERY_PLANNING_ENABLED=true
SCIDATA_SEARCH_MAX_QUERIES=5

# Default task guardrails
SCIDATA_DEFAULT_MAX_SOURCES=50
SCIDATA_DEFAULT_MAX_DOWNLOAD_BYTES=524288000
SCIDATA_DEFAULT_MODEL_TOKEN_BUDGET=100000
